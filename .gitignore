*.log
test_logs/
worklog/

# Local data and backups
docs_backup_*/
api/
hivemind-rs/api/
hivemind-rs/bt_torrents/
test_tasks/

# Misc local state
*.db
*.sqlite
*.sqlite3
*.pid
*.pid.lock
*.seed
*.tmp
*.temp
*.bak
*.backup
*.orig
*.old
