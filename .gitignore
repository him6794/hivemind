# Local environment
.env
.env.*
!.env.example
!frontend/.env.example

# Dependency caches
node_modules/
.cargo/
.rustup/

# Build outputs and compiler caches
target/
hivemind-rs/target-*/
dist/
frontend/**/dist/
subagents/sandbox-egress/target/
hivemind-rs/target-alt/
hivemind-rs/target-local/
tmp/

# Downloaded dependencies and release artifacts
.cache/
artifacts/
vendor/

# Python caches
__pycache__/
scripts/__pycache__/
*.py[cod]

# Logs and test artifacts
*.log
logs/
test_logs/
worklog/

# Local data and backups
docs_backup_*/
api/
hivemind-rs/api/
hivemind-rs/bt_torrents/
bt_torrents/
test_tasks/
sandbox/
sandbox-remote-worker/

# Misc local state
*.db
*.sqlite
*.sqlite3
*.pid
*.pid.lock
*.seed
*.tmp
*.temp
*.bak
*.backup
*.orig
*.old
worker_credentials.json
task_state.json
job_queue.json
config/local.yaml
config/secrets.yaml

# Superdesign local temp
.superdesign/tmp/
