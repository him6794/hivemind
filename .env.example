# Hivemind local configuration

# Database and cache
DATABASE_URL=postgres://hivemind:hivemind@localhost:5432/hivemind
REDIS_URL=redis://localhost:6379
POSTGRES_USER=hivemind
POSTGRES_PASSWORD=change-me-in-production
POSTGRES_DB=hivemind

# Service listen addresses
MASTER_HTTP_ADDR=0.0.0.0:8082
WEBSITE_HTTP_ADDR=0.0.0.0:8090
NODEPOOL_GRPC_ADDR=0.0.0.0:50051
WORKER_GRPC_ADDR=0.0.0.0:50053
WORKER_CONTROL_HTTP_ADDR=127.0.0.1:18080
# Worker process serves the control API and bundled worker-ui from this listener.
# Canonical Compose publishes worker gRPC on loopback by default.
# For a multi-host deployment, set this to the intended host interface and
# also set WORKER_ADVERTISE_ADDR to the worker's routable host:port.
WORKER_GRPC_BIND_HOST=127.0.0.1
# Worker control HTTP is local-only by default; set explicitly for remote operator access.
WORKER_CONTROL_BIND_HOST=127.0.0.1
MASTER_UI_DIR=./frontend/master-ui/dist
WORKER_UI_DIR=./frontend/worker-ui/dist

# Address advertised by a worker to nodepool.
# Set this when the worker is reachable at a different host/IP than WORKER_GRPC_ADDR.
# WORKER_ADVERTISE_ADDR=worker-hostname:50053

# Worker identity
WORKER_ID=worker-1
WORKER_LOCATION=local

# Control-plane authentication for master/user tokens. Required by master and nodepool.
JWT_SECRET=
# Worker RPC authentication. Set a distinct value shared only by nodepool and workers.
WORKER_EXECUTION_SECRET=
# Comma-separated admin usernames allowed to access /api/admin/* endpoints.
# Configured names are reserved from public HTTP and gRPC registration.
HIVEMIND_ADMIN_USERS=
# Per-user task submissions allowed within a rolling 1-minute window (0 = unlimited)
HIVEMIND_TASK_SUBMIT_LIMIT_PER_MINUTE=60

# Torrent task package distribution (nodepool is the trusted seeder/tracker)
TORRENT_API_DIR=./api/torrents
TORRENT_BT_DIR=./bt_torrents
TORRENT_ANNOUNCE_URL=http://localhost:6969/announce
TORRENT_TRACKER_LISTEN_ADDR=0.0.0.0:6969
TORRENT_SEED_LISTEN_ADDR=0.0.0.0:6881
# Host that workers should use when connecting to the nodepool seeder.
# For docker compose workers, use the service DNS name (not 127.0.0.1):
# TORRENT_SEED_ADVERTISE_HOST=nodepool
# Legacy optional HTTP artifact base URL (not the primary distribution path)
TORRENT_TASK_ARTIFACT_BASE_URL=

# Executor
MONTY_EXECUTABLE=monty.exe
EXECUTOR_SANDBOX_DIR=./sandbox
EXECUTOR_MAX_CPU_PERCENT=80
EXECUTOR_MAX_MEMORY_MB=4096
EXECUTOR_TASK_TIMEOUT_SECS=3600
EXECUTOR_MAX_CONCURRENT_TASKS=4

# VPN / Headscale coordination
HEADSCALE_URL=http://headscale:8080
HEADSCALE_LOGIN_SERVER=http://100.124.230.74:8080
HEADSCALE_API_KEY=
VPN_BASE_VIRTUAL_IP=100.64.0.0
VPN_NETWORK=100.64.0.0/10

# Frontend
# Master HTTP CORS is only for master-ui / requestor clients.
MASTER_CORS_ALLOWED_ORIGINS=http://localhost:3000,http://127.0.0.1:3000,http://localhost:5173,http://127.0.0.1:5173
# Official website API CORS is only for the public marketing/account site.
WEBSITE_CORS_ALLOWED_ORIGINS=http://localhost:3080,http://127.0.0.1:3080,http://localhost:5173,http://127.0.0.1:5173

# master-ui build arg (user-deployed master HTTP)
VITE_API_BASE=http://localhost:8082
VITE_MASTER_API_BASE=http://localhost:8082
# public website build arg (official website-api)
VITE_WEBSITE_API_BASE=http://localhost:8090
VITE_MASTER_UI=http://localhost:3000
VITE_WORKER_UI=http://localhost:3001
VITE_WORKER_CONTROL_BASE=http://localhost:18080

# Logging
LOG_LEVEL=info
DEBUG=false

# Worker nodepool auth (optional if WORKER_NODEPOOL_TOKEN is set)
WORKER_NODEPOOL_USERNAME=replace-me-after-provisioning
WORKER_NODEPOOL_PASSWORD=replace-me-with-a-strong-password
# Aliases: WORKER_USERNAME / WORKER_PASSWORD
