# Hivemind 環境變數配置範例
# 複製此檔案為 .env 並填入實際值

# ============================================
# Nodepool 服務配置
# ============================================

# Redis 連線位址
NODEPOOL_REDIS_ADDR=localhost:6379

# PostgreSQL 連線字串
NODEPOOL_POSTGRES_DSN=postgres://hivemind:hivemind@localhost:5432/hivemind?sslmode=disable

# 任務超時秒數（DISPATCHED 狀態無響應的超時時間）
NODEPOOL_TASK_TIMEOUT_SEC=30

# 最大重新分配次數（任務失敗後重試次數）
NODEPOOL_MAX_REDISPATCH=2

# 啟用 HTTP 認證（1=啟用, 0=停用）
NODEPOOL_ENABLE_HTTP_AUTH=1

# Nodepool gRPC 監聽位址
NODEPOOL_GRPC_ADDR=:50051

# Nodepool HTTP 監聽位址（用於健康檢查和 API）
NODEPOOL_HTTP_ADDR=:8080

# JWT Secret（用於生成和驗證 JWT Token）
NODEPOOL_JWT_SECRET=your-secret-key-change-in-production

# ============================================
# Master 服務配置
# ============================================

# Master HTTP 監聽端口
MASTER_HTTP_PORT=8082

# Nodepool gRPC 位址（Master 連線到 Nodepool）
MASTER_NODEPOOL_GRPC=localhost:50051

# BitTorrent 公開 URL 基礎路徑（留空自動生成）
BT_PUBLIC_BASE_URL=

# Torrent 檔案存儲路徑
MASTER_TORRENT_DIR=./api/torrents

# ============================================
# Worker 服務配置
# ============================================

# Worker gRPC 監聽位址
WORKER_ADDR=:50053

# Nodepool gRPC 位址（Worker 連線到 Nodepool）
WORKER_NODEPOOL_ADDR=localhost:50051

# Worker 名稱（唯一識別碼）
WORKER_NAME=worker-1

# Worker 位置標籤
WORKER_LOCATION=default

# ============================================
# 前端配置
# ============================================

# Master UI API 基礎 URL
VITE_API_BASE=http://localhost:8082

# Worker UI API 基礎 URL
VITE_WORKER_API_BASE=http://localhost:8082

# ============================================
# 資料庫配置（Docker）
# ============================================

# PostgreSQL
POSTGRES_USER=hivemind
POSTGRES_PASSWORD=hivemind
POSTGRES_DB=hivemind

# Redis（通常不需要配置，使用預設值）
# REDIS_PASSWORD=

# ============================================
# 開發環境配置
# ============================================

# Go 環境
GO_ENV=development

# 日誌等級（debug, info, warn, error）
LOG_LEVEL=info

# 啟用詳細日誌
DEBUG=false

# ============================================
# 生產環境注意事項
# ============================================
# 1. 修改所有密碼和 Secret
# 2. 啟用 HTTPS
# 3. 設定適當的 CORS 來源
# 4. 啟用 rate limiting
# 5. 配置備份策略
