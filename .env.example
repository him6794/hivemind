# Hivemind local configuration

# Database and cache
DATABASE_URL=postgres://hivemind:hivemind@localhost:5432/hivemind
REDIS_URL=redis://localhost:6379
POSTGRES_USER=hivemind
POSTGRES_PASSWORD=hivemind
POSTGRES_DB=hivemind

# Service listen addresses
MASTER_HTTP_ADDR=0.0.0.0:8082
NODEPOOL_GRPC_ADDR=0.0.0.0:50051
WORKER_GRPC_ADDR=0.0.0.0:50053
WORKER_CONTROL_HTTP_ADDR=127.0.0.1:18080

# Address advertised by a worker to nodepool.
# Set this when the worker is reachable at a different host/IP than WORKER_GRPC_ADDR.
# WORKER_ADVERTISE_ADDR=worker-hostname:50053

# Worker identity
WORKER_ID=worker-1
WORKER_LOCATION=local

# Authentication
JWT_SECRET=change-me-in-production
# Comma-separated admin usernames allowed to access /api/admin/* endpoints
HIVEMIND_ADMIN_USERS=testuser
# Per-user task submissions allowed within a rolling 1-minute window (0 = unlimited)
HIVEMIND_TASK_SUBMIT_LIMIT_PER_MINUTE=60

# Torrent task package distribution
TORRENT_API_DIR=./api/torrents
TORRENT_BT_DIR=./bt_torrents
TORRENT_ANNOUNCE_URL=http://localhost:6969/announce

# Executor
MONTY_EXECUTABLE=monty.exe
EXECUTOR_SANDBOX_DIR=./sandbox
EXECUTOR_MAX_CPU_PERCENT=80
EXECUTOR_MAX_MEMORY_MB=4096
EXECUTOR_TASK_TIMEOUT_SECS=3600
EXECUTOR_MAX_CONCURRENT_TASKS=4

# VPN / Headscale coordination
HEADSCALE_URL=http://localhost:8080
HEADSCALE_API_KEY=
VPN_BASE_VIRTUAL_IP=100.64.0.0
VPN_NETWORK=100.64.0.0/10

# Frontend
VITE_API_BASE=http://localhost:8082
VITE_WORKER_CONTROL_BASE=http://localhost:18080

# Logging
LOG_LEVEL=info
DEBUG=false
